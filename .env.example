# Copy this file to .env and fill in real values.

# Required Telegram bot token.
BOT_TOKEN=

# Optional comma-separated Telegram user IDs with admin access.
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# Base data directory for catalog.json and the default SQLite database file.
YUQA_DATA_DIR=data/yuqa

# Optional explicit SQLAlchemy database URL.
# Leave blank to use SQLite at <YUQA_DATA_DIR>/yuqa.db.
# For the provided Docker image, use sqlite:////data/yuqa.db if overriding.
DATABASE_URL=

# Whether to apply Alembic migrations automatically on startup.
YUQA_AUTO_MIGRATE=true
